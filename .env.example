# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vortem
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=vortem
# Port exposed on the host (optional, defaults to 5433)
POSTGRES_PORT=5433

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production
# Port exposed on the host (optional, defaults to 6380)
REDIS_PORT=6380

# ─── Application ──────────────────────────────────────────────────────────────
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
SECRET_KEY=replace_with_at_least_32_character_random_string_here_now

# development | staging | production
ENVIRONMENT=development

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# JSON array of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Docker build ─────────────────────────────────────────────────────────────
# development (includes dev dependencies + hot-reload)
# production  (slim, no dev deps)
BUILD_TARGET=development

# Host port for the backend API
BACKEND_PORT=8000
